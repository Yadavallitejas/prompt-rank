# PromptRank Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://promptrank:promptrank@localhost:5432/promptrank

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM Provider ("openai" for production, "ollama" for local testing)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini

# Ollama (local testing — set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Evaluation Defaults
EVAL_SAMPLING_N=5
EVAL_FIXED_TEMPERATURE=0.7
EVAL_MAX_TOKENS=2048
